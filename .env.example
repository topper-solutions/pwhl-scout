# Required environment variables for PWHL Gameday
# Copy this file to .env.local and fill in the values.
#
# SECURITY NOTE: These keys are publicly visible in the PWHL website's
# client-side JavaScript (thepwhl.com). They are not secret credentials
# but are kept in env vars as a best practice to avoid hardcoding and
# to support key rotation if needed.

HOCKEYTECH_API_KEY=your_hockeytech_api_key
HOCKEYTECH_CLIENT_CODE=pwhl
FIREBASE_AUTH_TOKEN=your_firebase_auth_token
FIREBASE_API_KEY=your_firebase_api_key

# Optional: set when deploying under a subpath (e.g., /pwhl-gameday)
# NEXT_PUBLIC_BASE_PATH=/pwhl-gameday
